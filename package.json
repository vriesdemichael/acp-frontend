{
  "name": "acp-frontend",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "tsx watch backend/src/index.ts",
    "storybook": "storybook dev -p 6006 --host 0.0.0.0",
    "build:storybook": "storybook build",
    "build:frontend": "vite build",
    "build:backend": "tsc -p backend/tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "lint": "eslint .",
    "typecheck": "tsc -p frontend/tsconfig.json && tsc -p backend/tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@hono/node-server": "^1.19.11",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.8",
    "marked": "^17.0.5",
    "svelte": "^5.55.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@storybook/svelte": "10.3.4",
    "@storybook/svelte-vite": "10.3.4",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
